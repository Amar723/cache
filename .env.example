# Copy this file to ".env" and fill in real values.
# react-native-config reads this file at build time and exposes the values
# via `import Config from 'react-native-config'`.

# Supabase — Project Settings -> API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key

# Google Maps SDK keys (native map rendering). TWO separate keys, because a
# Google Cloud key can be restricted to only ONE platform type:
#   - iOS key     → restrict to "iOS apps" (bundle id) + API "Maps SDK for iOS"
#   - Android key → restrict to "Android apps" (package + SHA-1) + "Maps SDK for Android"
GOOGLE_MAPS_API_KEY_IOS=your-ios-maps-key
GOOGLE_MAPS_API_KEY_ANDROID=your-android-maps-key

# NOTE: the Places (address autocomplete) key is NOT a client value. It lives
# only as a Supabase Edge Function secret so it never ships in the app:
#   supabase secrets set GOOGLE_PLACES_API_KEY=your-places-key
#   supabase functions deploy places

# Optional — crash/error reporting (Sentry). Leave blank to keep monitoring off.
# Create a project at sentry.io → Settings → Client Keys (DSN).
SENTRY_DSN=
